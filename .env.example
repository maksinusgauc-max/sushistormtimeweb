# ── Переменные окружения (App Platform → Настройки → Переменные) ──
# Скопировать как образец; реальные значения в код НЕ коммитить.

# База данных (Timeweb Managed PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/dbname
# либо по частям вместо DATABASE_URL:
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# PGSSL=disable   # раскомментировать ТОЛЬКО если БД без TLS (обычно не нужно)


# Redis (Timeweb Managed Redis) — для лимитов запросов.
# Необязательно: если не задан, лимиты работают в памяти процесса.
# rediss:// — если включишь TLS в настройках базы.
REDIS_URL=redis://default:password@host:6379

# Вход сотрудника (сайт/киоск/админка меню)
ADMIN_PASS=
# ADMIN_LOGIN=admin   # необязательно

# Приём заказов во ФронтПад
FRONTPAD_SECRET=

# ИИ-чат
ANTHROPIC_API_KEY=

# Эквайринг Т-Банка
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# Система налогообложения ИП для чека 54-ФЗ (уточни у бухгалтера!):
#   usn_income | usn_income_outcome | osn | envd | esn | patent
TBANK_TAXATION=usn_income
# Ставка НДС позиции: none (УСН без НДС) | vat0 | vat10 | vat20 | vat110 | vat120
TBANK_VAT=none
# Автоотправка чека в Т-Банк: off (по умолч.) — вы пробиваете чек вручную на терминале.
# Поставь on, только если хочешь, чтобы Т-Банк фискализировал онлайн-оплату сам.
TBANK_RECEIPT=off

# PORT задаёт App Platform автоматически; локально можно не указывать.
